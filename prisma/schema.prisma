generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  super_admin
  org_admin
  editor
  viewer
}

enum TokenType {
  refresh
  reset_password
}

enum InvitationStatus {
  pending
  accepted
  expired
  revoked
}

enum ProjectStatus {
  draft
  uploading
  processing
  completed
  failed
}

enum SourceVideoStatus {
  uploaded
  processing
  ready
  failed
}

enum JobStatus {
  queued
  uploading
  uploaded
  analyzing
  segmenting
  captioning
  rendering
  completed
  failed
}

enum ClipStatus {
  draft
  ready
  exported
  failed
}

enum ExportStatus {
  requested
  processing
  completed
  failed
}

enum TargetPlatform {
  youtube_shorts
  tiktok
  instagram_reels
}

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  name            String
  passwordHash    String
  role            Role            @default(viewer)
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?
  memberships     Membership[]
  invitationsSent Invitation[]    @relation("InvitationSender")
  projectsCreated Project[]       @relation("ProjectCreator")
  processingJobs  ProcessingJob[]
  sourceVideos    SourceVideo[]
  refreshTokens   RefreshToken[]
  auditLogs       AuditLog[]      @relation("AuditActor")
  organizations   Organization[]  @relation("OrganizationOwner")

  @@index([deletedAt])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  type      TokenType @default(refresh)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([expiresAt])
}

model Organization {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  ownerId     String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  memberships Membership[]
  workspaces  Workspace[]
  invitations Invitation[]
  owner       User         @relation("OrganizationOwner", fields: [ownerId], references: [id], onDelete: Restrict)

  @@index([ownerId])
}

model Workspace {
  id             String        @id @default(cuid())
  organizationId String
  name           String
  slug           String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships    Membership[]
  invitations    Invitation[]
  projects       Project[]
  sourceVideos   SourceVideo[]

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model Membership {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  workspaceId    String?
  role           Role         @default(viewer)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace      Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId, workspaceId])
  @@index([organizationId])
  @@index([workspaceId])
}

model Invitation {
  id             String           @id @default(cuid())
  email          String
  tokenHash      String           @unique
  organizationId String
  workspaceId    String
  invitedById    String
  role           Role
  status         InvitationStatus @default(pending)
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy      User             @relation("InvitationSender", fields: [invitedById], references: [id], onDelete: Restrict)

  @@index([workspaceId, email])
}

model SourceVideo {
  id              String            @id @default(cuid())
  workspaceId     String
  uploadedById    String
  fileName        String
  mimeType        String
  sizeBytes       BigInt
  storagePath     String
  durationSeconds Float?
  status          SourceVideoStatus @default(uploaded)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  workspace       Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  uploadedBy      User              @relation(fields: [uploadedById], references: [id], onDelete: Restrict)
  projects        Project[]

  @@index([workspaceId])
}

model Project {
  id              String           @id @default(cuid())
  workspaceId     String
  title           String
  description     String?
  sourceVideoId   String?
  platformTargets TargetPlatform[]
  status          ProjectStatus    @default(draft)
  createdBy       String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourceVideo     SourceVideo?     @relation(fields: [sourceVideoId], references: [id], onDelete: SetNull)
  creator         User             @relation("ProjectCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  jobs            ProcessingJob[]
  clips           Clip[]

  @@index([workspaceId])
  @@index([sourceVideoId])
  @@index([createdBy])
}

model ProcessingJob {
  id           String    @id @default(cuid())
  projectId    String
  status       JobStatus @default(queued)
  progress     Int       @default(0)
  errorMessage String?
  createdBy    String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator      User      @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  clips        Clip[]

  @@index([projectId, status])
}

model Clip {
  id                String         @id @default(cuid())
  projectId         String
  jobId             String?
  title             String
  description       String?
  hookText          String?
  startTime         Float
  endTime           Float
  duration          Float
  score             Float?
  targetPlatform    TargetPlatform
  transcriptSnippet String?
  captionStyle      String?
  thumbnailUrl      String?
  exportUrl         String?
  status            ClipStatus     @default(draft)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  project           Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  job               ProcessingJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)
  captions          CaptionTrack[]
  exports           Export[]

  @@index([projectId])
}

model CaptionTrack {
  id        String   @id @default(cuid())
  clipId    String
  language  String   @default("en")
  style     String?
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  clip      Clip     @relation(fields: [clipId], references: [id], onDelete: Cascade)

  @@index([clipId])
}

model Export {
  id          String       @id @default(cuid())
  clipId      String
  format      String
  resolution  String
  status      ExportStatus @default(requested)
  downloadUrl String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  clip        Clip         @relation(fields: [clipId], references: [id], onDelete: Cascade)

  @@index([clipId, status])
}

model LandingContent {
  id           String   @id @default("landing-default")
  hero         Json
  marquee      Json
  features     Json
  workflow     Json
  testimonials Json
  stats        Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())
  actor     User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entity, entityId])
  @@index([actorId])
}
